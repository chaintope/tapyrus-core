        <number>8</number>
       </property>

       <item>
        <widget class="QFrame" name="frameIssue">
         <property name="frameShape">
          <enum>QFrame::StyledPanel</enum>
         </property>
         <property name="frameShadow">
          <enum>QFrame::Raised</enum>
         </property>
         <layout class="QVBoxLayout" name="issueFrameLayout">
          <property name="spacing">
           <number>10</number>
          </property>

          <!-- Section header -->
          <item>
           <layout class="QHBoxLayout" name="issueTitleRow">
            <item>
             <widget class="QLabel" name="labelIssueTitle">
              <property name="font">
               <font>
                <weight>75</weight>
                <bold>true</bold>
               </font>
              </property>
              <property name="text">
               <string>Issue Token</string>
              </property>
             </widget>
            </item>
            <item>
             <spacer name="issueTitleSpacer">
              <property name="orientation">
               <enum>Qt::Horizontal</enum>
              </property>
              <property name="sizeHint" stdset="0">
               <size>
                <width>40</width>
                <height>20</height>
               </size>
              </property>
             </spacer>
            </item>
           </layout>
          </item>

          <!-- Token Type row -->
          <item>
           <layout class="QHBoxLayout" name="typeRow">
            <item>
             <widget class="QLabel" name="labelTokenType">
              <property name="text">
               <string>Token Type:</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QRadioButton" name="radioReissuable">
              <property name="text">
               <string>&amp;REISSUABLE</string>
              </property>
              <property name="checked">
               <bool>true</bool>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QRadioButton" name="radioNonReissuable">
              <property name="text">
               <string>&amp;NON_REISSUABLE</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QRadioButton" name="radioNft">
              <property name="text">
               <string>N&amp;FT</string>
              </property>
             </widget>
            </item>
            <item>
             <spacer name="typeSpacer">
              <property name="orientation">
               <enum>Qt::Horizontal</enum>
              </property>
              <property name="sizeHint" stdset="0">
               <size>
                <width>40</width>
                <height>20</height>
               </size>
              </property>
             </spacer>
            </item>
           </layout>
          </item>

          <!-- Issue Mode: New / Reissue + token combo on one line (visible only for REISSUABLE) -->
          <item>
           <widget class="QWidget" name="issueModeWidget">
            <property name="visible">
             <bool>false</bool>
            </property>
            <layout class="QHBoxLayout" name="issueModeRow">
             <property name="leftMargin">
              <number>0</number>
             </property>
             <property name="topMargin">
              <number>0</number>
             </property>
             <property name="rightMargin">
              <number>0</number>
             </property>
             <property name="bottomMargin">
              <number>0</number>
             </property>
             <item>
              <widget class="QRadioButton" name="radioNew">
               <property name="text">
                <string>&amp;New</string>
               </property>
               <property name="checked">
                <bool>true</bool>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QRadioButton" name="radioReissue">
               <property name="text">
                <string>&amp;Reissue</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QComboBox" name="reissueCombo">
               <property name="enabled">
                <bool>false</bool>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
                 <horstretch>1</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
