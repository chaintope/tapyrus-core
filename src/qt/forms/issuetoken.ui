   <item>
    <widget class="QTabWidget" name="tabWidget">
     <property name="currentIndex">
      <number>0</number>
     </property>

     <!-- ==================== Issue Token tab ==================== -->
     <widget class="QWidget" name="tabIssue">
      <attribute name="title">
       <string>&amp;Issue Token</string>
      </attribute>
      <layout class="QVBoxLayout" name="issueTabLayout">
       <property name="spacing">
        <number>8</number>
       </property>
       <property name="leftMargin">
        <number>8</number>
       </property>
       <property name="topMargin">
        <number>8</number>
       </property>
       <property name="rightMargin">
        <number>8</number>
       </property>
