            </item>
            <item>
             <layout class="QHBoxLayout" name="issueAmountRow">
              <item>
               <widget class="QLabel" name="labelAmount">
                <property name="text">
                 <string>&amp;Amount:</string>
                </property>
                <property name="buddy">
                 <cstring>amountEdit</cstring>
                </property>
               </widget>
              </item>
              <item>
               <widget class="QValidatedLineEdit" name="amountEdit">
                <property name="placeholderText">
                 <string>Number of tokens to issue (fixed at 1 for NFT)</string>
                </property>
               </widget>
              </item>
             </layout>
            </item>
           </layout>
          </item>

          <!-- Issue / Clear buttons -->
          <item>
           <layout class="QHBoxLayout" name="issueButtonRow">
            <item>
             <widget class="QPushButton" name="clearButton">
              <property name="text">
               <string>C&amp;lear</string>
              </property>
