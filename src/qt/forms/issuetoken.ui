             </item>
             <item>
              <spacer name="issueModeSpacer">
               <property name="orientation">
                <enum>Qt::Horizontal</enum>
               </property>
               <property name="sizeHint" stdset="0">
                <size>
                 <width>20</width>
                 <height>20</height>
                </size>
               </property>
              </spacer>
             </item>
            </layout>
           </widget>
          </item>

          <!-- Label and Amount fields -->
          <item>
           <layout class="QVBoxLayout" name="issueFieldsLayout">
            <property name="spacing">
             <number>10</number>
            </property>
            <item>
             <layout class="QHBoxLayout" name="issueLabelRow">
              <item>
               <widget class="QLabel" name="labelIssueLabel">
                <property name="text">
                 <string>&amp;Label:</string>
                </property>
                <property name="buddy">
                 <cstring>issueLabelEdit</cstring>
                </property>
               </widget>
              </item>
              <item>
               <widget class="QLineEdit" name="issueLabelEdit">
                <property name="placeholderText">
                 <string>Optional label for this token</string>
                </property>
               </widget>
              </item>
