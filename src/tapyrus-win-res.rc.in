// Generated by CMake from src/tapyrus-win-res.rc.in — do not edit.
// Shared VERSIONINFO template for all Tapyrus Windows binaries. Per-binary
// values (name, description, icon) are substituted via configure_windows_rc()
// in cmake/module/AddWindowsResources.cmake.
@TAPYRUS_RC_ICON_LINE@
#include <windows.h>

#define VER_PRODUCTVERSION     @CLIENT_VERSION_MAJOR@,@CLIENT_VERSION_MINOR@,@CLIENT_VERSION_BUILD@,0
#define VER_PRODUCTVERSION_STR "@CLIENT_VERSION_MAJOR@.@CLIENT_VERSION_MINOR@.@CLIENT_VERSION_BUILD@"
#define VER_FILEVERSION        VER_PRODUCTVERSION
#define VER_FILEVERSION_STR    VER_PRODUCTVERSION_STR

VS_VERSION_INFO VERSIONINFO
FILEVERSION     VER_FILEVERSION
PRODUCTVERSION  VER_PRODUCTVERSION
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904E4" // U.S. English - multilingual (hex)
        BEGIN
            VALUE "CompanyName",        "Chaintope"
            VALUE "FileDescription",    "@TAPYRUS_RC_FILE_DESCRIPTION@"
            VALUE "FileVersion",        VER_FILEVERSION_STR
            VALUE "InternalName",       "@TAPYRUS_RC_BINARY_NAME@"
            VALUE "LegalCopyright",     "2009-@COPYRIGHT_YEAR@ @COPYRIGHT_HOLDERS_FINAL@"
            VALUE "LegalCopyright2",    "@COPYRIGHT_YEAR@-@COPYRIGHT_YEAR_CHAINTOPE@ @COPYRIGHT_HOLDER_CHAINTOPE@"
            VALUE "LegalTrademarks1",   "Distributed under the MIT software license, see the accompanying file COPYING or http://www.opensource.org/licenses/mit-license.php."
            VALUE "OriginalFilename",   "@TAPYRUS_RC_BINARY_NAME@.exe"
            VALUE "ProductName",        "@TAPYRUS_RC_PRODUCT_NAME@"
            VALUE "ProductVersion",     VER_PRODUCTVERSION_STR
        END
    END

    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0, 1252 // language neutral - multilingual (decimal)
    END
END
